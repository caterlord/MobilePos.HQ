# Database Provider Configuration
# Valid values: SqlServer, PostgreSQL
DB_PROVIDER=SqlServer

# ===============================
# MAIN POS DATABASE CONFIGURATION
# ===============================
# For SQL Server use DB_SERVER, for PostgreSQL use DB_HOST
DB_SERVER=your-server.database.windows.net
DB_HOST=your-postgresql-host.com
DB_PORT=5432
DB_NAME=your-pos-database-name
DB_USER=your-username
DB_PASSWORD=your-password

# PostgreSQL-specific SSL settings
DB_SSL_MODE=VerifyFull
DB_CHANNEL_BINDING=Require

# Optional: Connection pool settings
DB_MAX_POOL_SIZE=100
DB_MIN_POOL_SIZE=5
DB_CONNECTION_TIMEOUT=30

# ===============================
# ADMIN DATABASE CONFIGURATION
# ===============================
# Back office management: Regions, Territories, Distributor/Reseller profiles
# For SQL Server use ADMIN_DB_SERVER, for PostgreSQL use ADMIN_DB_HOST
ADMIN_DB_SERVER=your-server.database.windows.net
ADMIN_DB_HOST=your-postgresql-host.com
ADMIN_DB_PORT=5432
ADMIN_DB_NAME=your-admin-database-name
ADMIN_DB_USER=your-username
ADMIN_DB_PASSWORD=your-password

# PostgreSQL-specific SSL settings for Admin DB
ADMIN_DB_SSL_MODE=VerifyFull
ADMIN_DB_CHANNEL_BINDING=Require

# Application Settings
ASPNETCORE_ENVIRONMENT=Development

# ===============================
# CLERK CONFIGURATION
# ===============================
# Clerk Backend API secret key used for request verification, profile sync, and invitations
CLERK_SECRET_KEY=sk_test_your_secret_key

# Optional machine token / networkless verification settings
# CLERK_MACHINE_SECRET_KEY=msk_test_your_machine_secret_key
# CLERK_JWT_KEY="-----BEGIN PUBLIC KEY-----..."

# Optional comma-separated audience list if you verify custom audiences
# CLERK_AUDIENCES=

# Comma-separated list of allowed frontend origins for the azp/authorized party check
CLERK_ALLOWED_PARTIES=http://localhost:5173,http://localhost:5174

# Optional redirect URL used for Clerk invitation emails
CLERK_INVITATION_REDIRECT_URL=http://localhost:5173/sign-up

# Email provider (required at app startup)
SENDGRID_API_KEY=your-sendgrid-api-key

# ===============================
# AZURE LOG ANALYTICS AUDIT (OPTIONAL)
# ===============================
# Enable Azure audit ingestion for request/mutation events
AZURE_LOG_AUDIT_ENABLED=false

# Data Collection Endpoint URI (DCE) for Logs Ingestion API
# Example: https://<dce-name>.<region>-1.ingest.monitor.azure.com
AZURE_LOG_AUDIT_ENDPOINT=

# Immutable Data Collection Rule ID
# Example: dcr-00000000000000000000000000000000
AZURE_LOG_AUDIT_DCR_IMMUTABLE_ID=

# DCR stream names
AZURE_LOG_AUDIT_REQUEST_STREAM=Custom-HqRequestAudit
AZURE_LOG_AUDIT_MUTATION_STREAM=Custom-HqDataMutationAudit

# Optional explicit service principal credentials for ingestion
# If omitted, DefaultAzureCredential chain is used
AZURE_LOG_AUDIT_TENANT_ID=
AZURE_LOG_AUDIT_CLIENT_ID=
AZURE_LOG_AUDIT_CLIENT_SECRET=

# Optional Azure Monitor OpenTelemetry request telemetry export
APPLICATIONINSIGHTS_CONNECTION_STRING=
AZURE_MONITOR_SAMPLING_RATIO=1.0
AZURE_MONITOR_ENABLE_LIVE_METRICS=false
